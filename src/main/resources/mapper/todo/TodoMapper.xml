<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.templete.domain.todo.mapper.TodoMapper">
    <select id="selectTodoById" resultType="TodoResponse">
        SELECT
            todo_id, todo_name, todo_start_time, todo_end_time, todo_status
        FROM todo
        WHERE todo_id = #{todoId}
    </select>
</mapper>